// ===== GOOGLE LOGIN =====
function handleGoogleLogin() {
    // Initialize Google Sign-In
    if (typeof google !== 'undefined' && google.accounts) {
        google.accounts.id.initialize({
            client_id: GOOGLE_CLIENT_ID,
            callback: handleGoogleResponse
        });
        google.accounts.id.prompt();
    } else {
        // Fallback: Simulate successful login for demo
        simulateGoogleLogin();
    }
}

function handleGoogleResponse(response) {
    // Decode JWT token to get user info
    try {
        const payload = JSON.parse(atob(response.credential.split('.')[1]));
        loginUser(payload);
    } catch (e) {
        console.error('Google login error:', e);
        simulateGoogleLogin();
    }
}

function simulateGoogleLogin() {
    // Demo login for when Google API isn't fully configured
    const mockUser = {
        name: 'Demo User',
        email: 'demo@bulshokaab.com',
        picture: 'https://ui-avatars.com/api/?name=Demo+User&background=00d4ff&color=fff&size=128'
    };
    loginUser(mockUser);
}

function loginUser(userData) {
    // Save user to localStorage
    localStorage.setItem('bulshoUser', JSON.stringify(userData));
    
    // Update UI
    const loginBtn = document.getElementById('googleLoginBtn');
    const userProfile = document.getElementById('userProfile');
    const userAvatar = document.getElementById('userAvatar');
    const userName = document.getElementById('userName');

    if (loginBtn) loginBtn.style.display = 'none';
    if (userProfile) {
        userProfile.style.display = 'flex';
        userAvatar.src = userData.picture || 'https://ui-avatars.com/api/?name=User&background=00d4ff&color=fff&size=128';
        userName.textContent = userData.name || userData.email || 'User';
    }

    // Show success notification
    showNotification(`Welcome, ${userData.name || 'User'}!`, 'success');
}

function logout() {
    localStorage.removeItem('bulshoUser');
    
    const loginBtn = document.getElementById('googleLoginBtn');
    const userProfile = document.getElementById('userProfile');

    if (loginBtn) loginBtn.style.display = 'block';
    if (userProfile) userProfile.style.display = 'none';

    // If on dashboard, redirect to home
    if (window.location.pathname.includes('dashboard')) {
        window.location.href = 'index.html';
    }

    showNotification('Logged out successfully', 'info');
}

function checkLoginStatus() {
    const userData = JSON.parse(localStorage.getItem('bulshoUser'));
    if (userData) {
        loginUser(userData);
    }
}

// ===== NOTIFICATION SYSTEM =====
function showNotification(message, type = 'info') {
    const notif = document.createElement('div');
    notif.className = `notification ${type}`;
    notif.innerHTML = `
        <span>${message}</span>
        <button onclick="this.parentElement.remove()">&times;</button>
    `;
    notif.style.cssText = `
        position: fixed;
        bottom: 20px;
        right: 20px;
        padding: 16px 24px;
        border-radius: 12px;
        background: ${type === 'success' ? '#00c853' : type === 'info' ? '#2196f3' : '#ff5252'};
        color: white;
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        z-index: 3000;
        display: flex;
        align-items: center;
        gap: 15px;
        animation: slideIn 0.3s ease;
    `;
    const style = document.createElement('style');
    style.textContent = `
        @keyframes slideIn {
            from { transform: translateX(100%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
    `;
    document.head.appendChild(style);
    document.body.appendChild(notif);

    setTimeout(() => {
        notif.style.opacity = '0';
        notif.style.transition = 'opacity 0.3s ease';
        setTimeout(() => notif.remove(), 300);
    }, 4000);
}

